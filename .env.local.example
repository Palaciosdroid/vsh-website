# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server-only, never expose

# Mapbox (Phase 3: Therapeuten-Karte)
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
# MAPBOX_SECRET_TOKEN=your-mapbox-secret-token  # Server-only, Geocoding

# hCaptcha (Phase 3: Kontaktformular-Schutz)
# NEXT_PUBLIC_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
# HCAPTCHA_SECRET=your-hcaptcha-secret

# E-Mail (Phase 4/5: Benachrichtigungen)
# SMTP_HOST=smtp.example.com
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-pass

# Cron-Jobs (Phase 4: Event-Erinnerungen, Membership-Check)
# CRON_SECRET=your-cron-secret

# Site
# NEXT_PUBLIC_SITE_URL=https://v-s-h.ch
